{
  "buildCommand": "CI=false react-scripts build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "CI": "false",
    "DISABLE_ESLINT_PLUGIN": "true",
    "GENERATE_SOURCEMAP": "false"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
