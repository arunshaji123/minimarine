                            className={`px-2 py-1 rounded text-xs font-medium ${complianceStatus.solas.hull === 'pending' ? 'bg-yellow-100 text-yellow-800 border border-yellow-300' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
